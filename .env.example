# contest_front 生产环境配置模板
#
# 通用配置方式：
# 1) 先确定 BASE_PATH
#    - 子路径部署（示例）：https://domain.com/contest/ -> BASE_PATH=/contest
#    - 子域名根路径部署（示例）：https://contest.domain.com/ -> BASE_PATH=（空）
# 2) 按 README 的“环境变量映射规则”替换下方值
#
# 当前文件给出的是示例值：BASE_PATH=/contest

# Vite 构建基路径（必须与 Nginx 发布路径一致）
VITE_PUBLIC_BASE=/contest/

# API 前缀（由网关/反向代理转发到后端）
VITE_CONTEST_API_PREFIX=/contest/api

# 首页路由（系统主入口）
# 子路径部署示例：/contest/
# 根路径部署示例：/
VITE_CONTEST_HOME_URL=/contest/

# 登录页“匹配路径前缀”（前端路由识别用）
VITE_LOGIN_PATH_PREFIX=/contest/login

# 登录页“跳转目标地址”（代码中跳转到登录页时使用）
# 一般与 VITE_LOGIN_PATH_PREFIX 保持一致
VITE_LOGIN_PAGE_URL=/contest/login

# 注册页“匹配路径前缀”
VITE_REGISTER_PATH_PREFIX=/contest/sign-up

# 注册页“跳转目标地址”
# 一般与 VITE_REGISTER_PATH_PREFIX 保持一致
VITE_REGISTER_PAGE_URL=/contest/sign-up

# “我的比赛”页面路由
VITE_CONTEST_MY_CONTESTS_PATH=/contest/my-contests

# “创办比赛”页面路由
VITE_CONTEST_CREATE_PATH=/contest/create

# “我创办的比赛”页面路由
VITE_CONTEST_MINE_PATH=/contest/mine

# “个人信息”页面路由
VITE_CONTEST_PROFILE_PATH=/contest/profile

# “我评审的比赛”列表页路由（进入具体评审页时会拼接 /:competitionId）
VITE_CONTEST_JUDGE_REVIEWS_PATH=/contest/judge-reviews

# “用户同步审核”页面路由（仅管理员可见）
VITE_CONTEST_USER_SYNC_REVIEW_PATH=/contest/user-sync-review

# 比赛详情/报名分享链接前缀
# 最终会拼成：/contest/competitions/:id 或 /contest/competitions/:id/register
VITE_CONTEST_COMPETITION_PATH_PREFIX=/contest/competitions

# 比赛报名后缀（拼接在 :id 后）
VITE_CONTEST_COMPETITION_REGISTER_SUFFIX=/register

# 是否在请求中携带 Cookie（axios.withCredentials）
# 后端使用 Cookie 鉴权时必须为 true
VITE_CONTEST_WITH_CREDENTIALS=true
